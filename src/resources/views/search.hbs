<form class="row g-3 mt-4" method="post">
  <div class="form-group col-auto">
    <label for="staticEmail2" class="visually-hidden">Search</label>
    <input type="text" name="q" class="form-control-plaintext" id="staticEmail2" placeholder="Search something">
  <div>
    <div class="form-group col-auto">
    <label for="gender-input" class="visually-hidden">Keyword</label>
    <select name="gender" id="input" class="form-control">
        <option value="">--Select gender--</option>
        <option value="male">Male</option>
        <option value="female">Female</option>
    </select>
  <div>
    <button type="submit" class="btn btn-primary mb-3">Submit</button>
</form>